# --- LLM (optional, without a key the app runs in demo mode) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OBS_MODEL=openai:gpt-4.1     # overrides OPENAI_MODEL for the hosted agents

# --- persistence (voice bookings, saved quotes, custom personas, run log) ---
# OBS_DATA_DIR=/app/data       # mount a volume here so agents survive a redeploy

# --- the desk seam (agents 04 and 05 read live positioning over HTTP) ---
# Unset it to run the observatory with no desk at all: the tools then report
# the feed as unavailable instead of inventing numbers.
# DESK_API_URL=https://desk.b4rruf3t.com

# --- agent builder: minting custom voice personas ---
# Unset means creation is CLOSED (fails shut, not open).
# OBS_ADMIN_TOKEN=...

# --- desk ingest: Marcus's trade decisions (POST /api/desk/runs) ---
# Unset means ingest is CLOSED (fails shut): a public box must not carry an
# open write endpoint. The compose file hands the same token to the desk.
# OBS_INGEST_TOKEN=...

# --- repo RAG agent: which checkout it indexes (default: this repo) ---
# OBS_REPO_PATH=/app

# --- LangSmith tracing (optional) ---
# LANGCHAIN_TRACING_V2=true
# LANGSMITH_API_KEY=lsv2_...
# LANGCHAIN_PROJECT=agent-observatory

# --- Langflow bridge (optional) ---
# LANGFLOW_URL=http://localhost:7860
# LANGFLOW_FLOW_ID=...
# LANGFLOW_API_KEY=...

# --- spend guard (backend/spend.py) ---
# OBS_DAILY_USD=2.00          # daily cap, requests refused above it
# OBS_MONTHLY_USD=20.00       # monthly cap
# OBS_COOLDOWN_S=20           # seconds between requests from one IP
# OBS_MAX_CONCURRENT=2        # requests in flight at once
# OBS_SPEND_DB=/app/data/spend.db
# OBS_ALERT_TO=igor.yago@gmail.com
# OBS_SES_FROM=observatory@b4rruf3t.com   # unset means alerts are only logged
# OBS_SES_REGION=eu-central-1
